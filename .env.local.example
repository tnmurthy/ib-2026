# ============================================================
# Innovat Bharat — Environment Variables
# Copy this file to .env.local for local development.
# Set these same variables in Render Dashboard > Environment.
# .env.local is gitignored — never commit real keys.
# ============================================================

# Resend API key — get it free at https://resend.com
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives all form submissions
IB_TEAM_EMAIL=info@innovatbharat.org

# "From" address used in sent emails.
# Must be a domain verified in your Resend account.
# During local dev use: onboarding@resend.dev
IB_FROM_EMAIL=noreply@innovatbharat.org

# Allowed CORS origin (your Render static site URL)
# During local dev: http://localhost:4200
ALLOWED_ORIGIN=https://innovat-bharat-web.onrender.com

# Port for the Express server (Render sets this automatically)
PORT=3000
