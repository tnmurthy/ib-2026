# ── Innovat Bharat Splash — Environment Variables ──────────────────────────
# Copy this file to .env.local for local testing (never commit .env.local)

# Google Sheets API — Service Account credentials
# 1. Go to https://console.cloud.google.com → IAM & Admin → Service Accounts
# 2. Create a service account, give it no roles
# 3. Generate a JSON key → copy client_email and private_key below
# 4. Create a new Google Sheet at https://sheets.google.com
# 5. Share it (Edit access) with the service account email
# 6. Copy the Sheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Server port (Render sets this automatically)
PORT=3001
